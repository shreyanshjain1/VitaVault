{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "phase03_patch",
    "**/phase03_patch/**",
    "*_patch",
    "**/*_patch/**",
    "phase*_patch",
    "**/phase*_patch/**",
    "**/*.tmp",
    "**/*.bak",
    "**/*.orig",
    "**/*.rej",
    "**/* copy.ts",
    "**/* copy.tsx",
    "**/app_actions_fixed.ts"
  ]
}
