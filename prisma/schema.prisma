generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AppRole {
  PATIENT
  CAREGIVER
  DOCTOR
  LAB_STAFF
  ADMIN
}

enum Sex {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum MedicationStatus {
  ACTIVE
  INACTIVE
  COMPLETED
}

enum MedicationLogStatus {
  TAKEN
  MISSED
  SKIPPED
}

enum AppointmentStatus {
  UPCOMING
  COMPLETED
  CANCELLED
}

enum LabFlag {
  NORMAL
  BORDERLINE
  HIGH
  LOW
}

enum SymptomSeverity {
  MILD
  MODERATE
  SEVERE
}

enum ReminderType {
  MEDICATION
  APPOINTMENT
  VACCINATION
  LAB_FOLLOW_UP
  GENERAL
}

enum DocumentType {
  PRESCRIPTION
  LAB_RESULT
  DISCHARGE_SUMMARY
  CERTIFICATE
  SCAN
  OTHER
}

enum CareAccessRole {
  CAREGIVER
  DOCTOR
  VIEWER
  LAB_STAFF
}

enum CareAccessStatus {
  PENDING
  ACTIVE
  REVOKED
  DECLINED
  EXPIRED
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  emailVerified DateTime?
  image        String?
  passwordHash String?
  role         AppRole  @default(PATIENT)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  accounts      Account[]
  sessions      Session[]
  healthProfile HealthProfile?
  doctors       Doctor[]
  medications   Medication[]
  medicationLogs MedicationLog[]
  appointments  Appointment[]
  labResults    LabResult[]
  vitalRecords  VitalRecord[]
  symptomEntries SymptomEntry[]
  vaccinations  VaccinationRecord[]
  documents     MedicalDocument[]
  reminders     Reminder[]

  ownedCareAccessGrants    CareAccess[]    @relation("CareAccessOwner")
  receivedCareAccessGrants CareAccess[]    @relation("CareAccessMember")
  grantedCareAccessGrants  CareAccess[]    @relation("CareAccessGrantedBy")
  ownedCareInvites         CareInvite[]    @relation("CareInviteOwner")
  sentCareInvites          CareInvite[]    @relation("CareInviteGrantedBy")
  ownedAccessAuditLogs     AccessAuditLog[] @relation("AccessAuditOwner")
  actorAccessAuditLogs     AccessAuditLog[] @relation("AccessAuditActor")
  ownedAiInsights          AiInsight[]     @relation("AiInsightOwner")
  generatedAiInsights      AiInsight[]     @relation("AiInsightGeneratedBy")
}

model HealthProfile {
  id                    String   @id @default(cuid())
  userId                String   @unique
  fullName              String
  dateOfBirth           DateTime?
  sex                   Sex?
  bloodType             String?
  heightCm              Float?
  weightKg              Float?
  emergencyContactName  String?
  emergencyContactPhone String?
  chronicConditions     String?
  allergiesSummary      String?
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Doctor {
  id        String   @id @default(cuid())
  userId    String
  name      String
  specialty String?
  clinic    String?
  phone     String?
  email     String?
  address   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  medications  Medication[]
  appointments Appointment[]
}

model Medication {
  id           String           @id @default(cuid())
  userId       String
  doctorId     String?
  name         String
  dosage       String
  frequency    String
  instructions String?
  startDate    DateTime
  endDate      DateTime?
  status       MedicationStatus @default(ACTIVE)
  active       Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  doctor    Doctor?             @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  schedules MedicationSchedule[]
  logs      MedicationLog[]
}

model MedicationSchedule {
  id           String   @id @default(cuid())
  medicationId String
  timeOfDay    String
  createdAt    DateTime @default(now())

  medication Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)
}

model MedicationLog {
  id           String              @id @default(cuid())
  userId       String
  medicationId String
  scheduleTime String?
  loggedAt     DateTime            @default(now())
  status       MedicationLogStatus
  notes        String?

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  medication Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)
}

model Appointment {
  id            String            @id @default(cuid())
  userId        String
  doctorId      String?
  clinic        String
  specialty     String?
  doctorName    String
  scheduledAt   DateTime
  purpose       String
  notes         String?
  followUpNotes String?
  status        AppointmentStatus @default(UPCOMING)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  doctor Doctor? @relation(fields: [doctorId], references: [id], onDelete: SetNull)
}

model LabResult {
  id             String   @id @default(cuid())
  userId         String
  testName       String
  dateTaken      DateTime
  resultSummary  String
  referenceRange String?
  flag           LabFlag  @default(NORMAL)
  filePath       String?
  fileName       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VitalRecord {
  id               String   @id @default(cuid())
  userId           String
  recordedAt       DateTime @default(now())
  systolic         Int?
  diastolic        Int?
  heartRate        Int?
  bloodSugar       Float?
  oxygenSaturation Int?
  temperatureC     Float?
  weightKg         Float?
  notes            String?
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SymptomEntry {
  id        String          @id @default(cuid())
  userId    String
  title     String
  severity  SymptomSeverity
  bodyArea  String?
  startedAt DateTime
  duration  String?
  trigger   String?
  notes     String?
  resolved  Boolean         @default(false)
  createdAt DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VaccinationRecord {
  id          String   @id @default(cuid())
  userId      String
  vaccineName String
  doseNumber  Int
  dateTaken   DateTime
  location    String?
  nextDueDate DateTime?
  notes       String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MedicalDocument {
  id        String       @id @default(cuid())
  userId    String
  title     String
  type      DocumentType
  filePath  String
  fileName  String
  mimeType  String
  sizeBytes Int
  notes     String?
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Reminder {
  id          String       @id @default(cuid())
  userId      String
  type        ReminderType
  title       String
  description String?
  dueAt       DateTime
  completed   Boolean      @default(false)
  createdAt   DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CareAccess {
  id                    String           @id @default(cuid())
  ownerUserId           String
  memberUserId          String
  accessRole            CareAccessRole
  status                CareAccessStatus @default(ACTIVE)
  canViewRecords        Boolean          @default(true)
  canEditRecords        Boolean          @default(false)
  canAddNotes           Boolean          @default(false)
  canExport             Boolean          @default(false)
  canGenerateAIInsights Boolean          @default(false)
  grantedByUserId       String?
  note                  String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  owner     User  @relation("CareAccessOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  member    User  @relation("CareAccessMember", fields: [memberUserId], references: [id], onDelete: Cascade)
  grantedBy User? @relation("CareAccessGrantedBy", fields: [grantedByUserId], references: [id], onDelete: SetNull)

  @@unique([ownerUserId, memberUserId])
  @@index([memberUserId, status])
}

model CareInvite {
  id                    String           @id @default(cuid())
  ownerUserId           String
  email                 String
  accessRole            CareAccessRole
  status                CareAccessStatus @default(PENDING)
  token                 String           @unique
  grantedByUserId       String
  canViewRecords        Boolean          @default(true)
  canEditRecords        Boolean          @default(false)
  canAddNotes           Boolean          @default(false)
  canExport             Boolean          @default(false)
  canGenerateAIInsights Boolean          @default(false)
  note                  String?
  expiresAt             DateTime
  acceptedAt            DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  owner     User @relation("CareInviteOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  grantedBy User @relation("CareInviteGrantedBy", fields: [grantedByUserId], references: [id], onDelete: Cascade)

  @@unique([ownerUserId, email])
  @@index([email, status])
}

model AccessAuditLog {
  id           String   @id @default(cuid())
  ownerUserId  String
  actorUserId  String?
  action       String
  targetType   String?
  targetId     String?
  metadataJson String?
  createdAt    DateTime @default(now())

  owner User  @relation("AccessAuditOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  actor User? @relation("AccessAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([ownerUserId, createdAt])
}

model AiInsight {
  id                    String   @id @default(cuid())
  ownerUserId           String
  generatedByUserId     String?
  title                 String
  summary               String
  adherenceRisk         String
  trendFlagsJson        String
  suggestedQuestionsJson String
  recommendedFollowUpJson String
  disclaimer            String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  owner       User  @relation("AiInsightOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  generatedBy User? @relation("AiInsightGeneratedBy", fields: [generatedByUserId], references: [id], onDelete: SetNull)

  @@index([ownerUserId, createdAt])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}