# VitaVault Environment Template
# Copy this file to .env for local development.
# Keep real secrets out of GitHub.

# -----------------------------------------------------------------------------
# Core application
# -----------------------------------------------------------------------------

# PostgreSQL connection used by Prisma and the app.
# Local Docker/Postgres example:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vitavault?schema=public"
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DB_NAME?schema=public"

# Public URL used by server-side links, emails, API docs, and readiness checks.
# Local example: http://localhost:3000
# Vercel example: https://your-project.vercel.app
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Enables reviewer-friendly demo fallbacks on public/demo surfaces.
# Use true locally or for portfolio demo deployments.
VITAVAULT_DEMO_MODE="true"
NEXT_PUBLIC_DEMO_MODE="true"

# -----------------------------------------------------------------------------
# Auth.js / NextAuth
# -----------------------------------------------------------------------------

# Use a long random secret in production.
# Generate one with: openssl rand -base64 32
AUTH_SECRET="change-this-to-a-long-random-string"

# Canonical Auth.js callback URL.
NEXTAUTH_URL="http://localhost:3000"

# On Vercel, keep this true so Auth.js trusts the deployment host.
AUTH_TRUST_HOST="true"

# -----------------------------------------------------------------------------
# Redis / BullMQ jobs
# -----------------------------------------------------------------------------

# Redis is used by worker-backed jobs, reminders, alerts, and queues.
# Local Redis example: redis://127.0.0.1:6379
REDIS_URL="redis://127.0.0.1:6379"
WORKER_CONCURRENCY="5"
JOB_DASHBOARD_LIMIT="20"

# Set to 1 when a build environment should not attempt Redis-backed work.
SKIP_REDIS_DURING_BUILD="1"

# -----------------------------------------------------------------------------
# AI insights
# -----------------------------------------------------------------------------

# Optional. AI insight features stay in fallback/demo mode without this key.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5-mini"

# -----------------------------------------------------------------------------
# Internal APIs and scheduled workflows
# -----------------------------------------------------------------------------

# Use a long random secret for internal job dispatch/API workflows in production.
INTERNAL_API_SECRET=""

# -----------------------------------------------------------------------------
# Account email workflows
# -----------------------------------------------------------------------------

EMAIL_VERIFICATION_REQUIRED="false"
RESEND_API_KEY=""
RESEND_FROM_EMAIL="VitaVault <no-reply@example.com>"

# -----------------------------------------------------------------------------
# Document storage
# -----------------------------------------------------------------------------

# Supported values: local, s3, r2.
DOCUMENT_STORAGE_PROVIDER="local"

# Local visibility mode. Use private for health documents.
# Supported values: private, public.
DOCUMENT_STORAGE_MODE="private"
PRIVATE_UPLOAD_DIR="private-uploads"

# Prefix used for S3/R2 object keys.
DOCUMENT_STORAGE_PREFIX="documents"

# S3-compatible document storage.
# Required when DOCUMENT_STORAGE_PROVIDER=s3.
S3_ENDPOINT=""
S3_REGION="us-east-1"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_FORCE_PATH_STYLE="true"

# Optional public base URL for public object links/CDN-backed previews.
S3_PUBLIC_BASE_URL=""

# Cloudflare R2-compatible aliases.
# Required when DOCUMENT_STORAGE_PROVIDER=r2 unless the S3_* aliases are used.
R2_ENDPOINT=""
R2_REGION="auto"
R2_BUCKET=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""

# Optional public base URL for R2 custom domain/CDN-backed previews.
R2_PUBLIC_BASE_URL=""

# -----------------------------------------------------------------------------
# Deployment / health checks
# -----------------------------------------------------------------------------

# Optional. Used by scripts/check-health-endpoint.cjs for deployed health checks.
HEALTHCHECK_URL="http://localhost:3000/api/health"
