{
  "name": "personal-health-record-companion",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "prisma generate && next build",
    "start": "next start",
    "seed": "tsx prisma/seed.ts",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "typecheck": "tsc --noEmit",
    "worker": "tsx --env-file=.env worker/index.ts",
    "worker:dev": "tsx watch --env-file=.env worker/index.ts",
    "postinstall": "prisma generate",
    "reminders:scan": "tsx scripts/scan-reminders.ts",
    "db:validate": "node scripts/prisma-validate.cjs",
    "db:validate:ci": "prisma validate",
    "check": "npm run db:validate && npm run typecheck",
    "repo:check": "node scripts/repo-hygiene-check.cjs",
    "verify": "npm run repo:check && npm run typecheck && npm run build"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.10.0",
    "@hookform/resolvers": "^4.1.3",
    "@prisma/client": "^6.6.0",
    "autoprefixer": "^10.4.20",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.56.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.37.0",
    "ioredis": "^5.4.1",
    "lucide-react": "^0.511.0",
    "next": "^15.3.3",
    "next-auth": "^5.0.0-beta.25",
    "next-themes": "^0.4.4",
    "openai": "^5.12.2",
    "postcss": "^8.5.3",
    "prisma": "^6.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.0.2",
    "sonner": "^2.0.1",
    "tailwind-merge": "^3.3.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.19.3",
    "tw-animate-css": "^1.3.0",
    "typescript": "^5.8.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.3.3"
  }
}
